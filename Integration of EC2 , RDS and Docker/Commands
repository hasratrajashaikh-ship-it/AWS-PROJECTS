•	sudo systemctl start docker
•	sudo systemctl status docker
•	sudo docker pull philippaul/node-mysql-app:02
•	sudo docker images


•	docker run --rm -p 80:3000 
-e DB_HOST="-db-hostname (database endpoint)" 
